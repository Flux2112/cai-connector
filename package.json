{
  "name": "cai-connector",
  "displayName": "CAI Connector",
  "description": "Create and connect to Cloudera AI sessions over SSH.",
  "version": "1.10.0",
  "publisher": "DefySoftwareSolutions",
  "repository": {
    "type": "git",
    "url": "https://github.com/Flux2112/cai-connector.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "cai-connector.png",
  "license": "GPL-3.0-or-later",
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cai-connector-sidebar",
          "title": "CAI Connector",
          "icon": "$(server)"
        }
      ]
    },
    "views": {
      "cai-connector-sidebar": [
        {
          "id": "caiConnector.sessionsView",
          "name": "Sessions"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "caiConnector.connect",
          "when": "view == caiConnector.sessionsView",
          "group": "navigation"
        },
        {
          "command": "caiConnector.refreshSessions",
          "when": "view == caiConnector.sessionsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "caiConnector.joinSession",
          "when": "view == caiConnector.sessionsView && viewItem == activeSession",
          "group": "inline"
        },
        {
          "command": "caiConnector.recreateSession",
          "when": "view == caiConnector.sessionsView && viewItem == activeSession",
          "group": "inline"
        },
        {
          "command": "caiConnector.recreateSession",
          "when": "view == caiConnector.sessionsView && viewItem == inactiveSession",
          "group": "inline"
        },
        {
          "command": "caiConnector.killSession",
          "when": "view == caiConnector.sessionsView && viewItem == activeSession",
          "group": "inline"
        }
      ]
    },
    "commands": [
      {
        "command": "caiConnector.connect",
        "title": "Connect",
        "category": "CAI Connector",
        "icon": "$(add)"
      },
      {
        "command": "caiConnector.disconnect",
        "title": "Disconnect",
        "category": "CAI Connector"
      },
      {
        "command": "caiConnector.browseRuntimes",
        "title": "Browse Runtimes",
        "category": "CAI Connector"
      },
      {
        "command": "caiConnector.clearCache",
        "title": "Clear Runtime Cache",
        "category": "CAI Connector"
      },
      {
        "command": "caiConnector.resetApiKey",
        "title": "Reset API Key",
        "category": "CAI Connector"
      },
      {
        "command": "caiConnector.reconnect",
        "title": "Recreate Last Session",
        "category": "CAI Connector"
      },
      {
        "command": "caiConnector.refreshSessions",
        "title": "Refresh Sessions",
        "category": "CAI Connector",
        "icon": "$(refresh)"
      },
      {
        "command": "caiConnector.joinSession",
        "title": "Join Session",
        "category": "CAI Connector",
        "icon": "$(plug)"
      },
      {
        "command": "caiConnector.recreateSession",
        "title": "Recreate Session",
        "category": "CAI Connector",
        "icon": "$(debug-rerun)"
      },
      {
        "command": "caiConnector.killSession",
        "title": "Kill Session",
        "category": "CAI Connector",
        "icon": "$(debug-stop)"
      }
    ],
    "configuration": {
      "title": "CAI Connector",
      "properties": {
        "caiConnector.cmlUrl": {
          "type": "string",
          "default": "",
          "description": "Cloudera AI (CML) base URL."
        },
        "caiConnector.cdswctlPath": {
          "type": "string",
          "default": "",
          "description": "Full path to cdswctl.exe. When empty, the extension looks for cdswctl.exe on PATH."
        },
        "caiConnector.defaultCpus": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "Default CPU count."
        },
        "caiConnector.defaultMemoryGb": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "description": "Default memory in GB."
        },
        "caiConnector.defaultGpus": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Default number of GPUs."
        },
        "caiConnector.cacheHours": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "description": "Runtime cache duration in hours."
        },
        "caiConnector.idleTimeoutMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "description": "Minutes of SSH inactivity before the endpoint auto-shuts down. Set to 0 to disable idle shutdown."
        },
        "caiConnector.latestRuntimesOnly": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, only the latest version of each runtime (grouped by editor, kernel, and edition) is shown in the runtime picker."
        },
        "caiConnector.openInSameWindow": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, the remote SSH session opens in the current window instead of a new window."
        },
        "caiConnector.autoReconnect": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, automatically reconnects to the last session on VS Code startup."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.4.5"
  }
}
